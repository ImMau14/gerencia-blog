---
export interface BreadcrumbItem {
  className?: string
  label: string
  href?: string
}

export interface Props {
  items: BreadcrumbItem[]
  className?: string
}

const { items, className = "" }: Props = Astro.props
---

<nav class={`font-b self-start text-sm text-white/50 ${className}`} aria-label="Breadcrumb">
  {
    items.map((item, i) => (
      <Fragment>
        {i > 0 && <span class="mx-1">/</span>}
        {item.href ? (
          <a href={item.href} class="transition-colors hover:text-white">
            {item.label}
          </a>
        ) : (
          <span class="text-white/70">{item.label}</span>
        )}
      </Fragment>
    ))
  }
</nav>
