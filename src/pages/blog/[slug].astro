---
import BaseLayout from "@/layouts/BaseLayout.astro"

import { getCollection, render } from "astro:content"

import Breadcrumb from "@/components/Breadcrumb.astro"

export async function getStaticPaths() {
  const posts = await getCollection("blog")
  return posts.map((post) => ({
    params: { slug: post.id },
  }))
}

const { slug } = Astro.params
const posts = await getCollection("blog")
const post = posts.find((p) => p.id === slug)

if (!post) {
  return new Response(null, { status: 404 })
}

const { Content } = await render(post)

const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
const currentIndex = sortedPosts.findIndex((p) => p.id === slug)

const prevPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null
const nextPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null
---

<BaseLayout title={`${post.data.title} - Gerencia Blog`}>
  <Breadcrumb
    items={[{ label: "Inicio", href: "/" }, { label: "Blog", href: "/blog" }, { label: post.data.title }]}
    className="animate-fade-in-down"
  />

  <article class="flex w-full flex-col items-center gap-6">
    <section class="flex w-full flex-col items-center gap-2">
      <h1
        class="font-h animate-fade-in-down animate-delay-100 metallic-text w-full text-4xl leading-tight font-bold tracking-wide text-white sm:text-center sm:text-5xl"
      >
        {post.data.title}
      </h1>

      <div
        class="font-b animate-fade-in-down animate-delay-200 mb-2 w-full text-start text-base text-white/70 sm:text-center"
      >
        <time datetime={post.data.pubDate.toISOString()}>
          {
            post.data.pubDate.toLocaleDateString("es", {
              year: "numeric",
              month: "short",
              day: "numeric",
            })
          }
        </time>
        <span> • </span>
        <span>{post.data.author}</span>
      </div>

      <p
        class="font-b animate-fade-in-down animate-delay-300 mb-2 text-start text-xl leading-relaxed text-white/70 sm:text-center"
      >
        {post.data.description}
      </p>

      {
        post.data.tags && (
          <div class="animate-fade-in-down animate-delay-400 my-4 flex w-full flex-wrap gap-2 sm:justify-center">
            {post.data.tags.map((tag) => (
              <span class="glass-card rounded-full px-6 py-2 font-medium text-white">#{tag}</span>
            ))}
          </div>
        )
      }
    </section>

    <div class="glass animate-fade-in-down animate-delay-500 w-full rounded-3xl p-6">
      <img
        src={post.data.banner ?? "/banners/default.webp"}
        alt=""
        class="h-106 w-full rounded-2xl border-2 border-white/20 object-cover"
      />
    </div>

    <div class="animate-fade-in-down animate-delay-600 w-full max-w-full overflow-x-auto">
      <div
        class="prose prose-invert font-b prose-img:w-full prose-img:rounded-3xl prose-img:p-6 prose-img:glass prose-pre:glass prose-pre:rounded-2xl prose-pre:!bg-transparent prose-lg no-code-backticks mt-10 mb-32 max-w-screen"
      >
        <Content className="w-full" />
      </div>
    </div>
  </article>

  <div class="animate-fade-in-down animate-delay-700 mb-6 w-full text-center">
    <a href="/blog" class="font-b text-sm text-white/50 transition-colors hover:text-white"> ← Volver al blog </a>
  </div>

  {
    (prevPost || nextPost) && (
      <nav class="animate-fade-in-down animate-delay-800 w-full">
        {prevPost && nextPost ? (
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <a
              href={`/blog/${prevPost.id}`}
              class="glass-card group flex flex-col gap-1 rounded-2xl p-4 text-white transition-colors hover:bg-white/10"
            >
              <span class="font-b text-xs tracking-wide text-white/50 uppercase">← Anterior</span>
              <span class="font-b line-clamp-2 text-sm group-hover:text-white/90">{prevPost.data.title}</span>
            </a>
            <a
              href={`/blog/${nextPost.id}`}
              class="glass-card group flex flex-col items-end gap-1 rounded-2xl p-4 text-right text-white transition-colors hover:bg-white/10"
            >
              <span class="font-b text-xs tracking-wide text-white/50 uppercase">Siguiente →</span>
              <span class="font-b line-clamp-2 text-sm group-hover:text-white/90">{nextPost.data.title}</span>
            </a>
          </div>
        ) : (
          <div class="flex justify-center">
            {prevPost && (
              <a
                href={`/blog/${prevPost.id}`}
                class="glass-card group flex w-full flex-col gap-1 rounded-2xl p-4 text-white sm:max-w-md"
              >
                <span class="font-b text-xs tracking-wide text-white/50 uppercase">← Anterior</span>
                <span class="font-b line-clamp-2 text-sm group-hover:text-white/90">{prevPost.data.title}</span>
              </a>
            )}
            {nextPost && (
              <a
                href={`/blog/${nextPost.id}`}
                class="glass-card group flex w-full flex-col items-end gap-1 rounded-2xl p-4 text-right text-white sm:max-w-md"
              >
                <span class="font-b text-xs tracking-wide text-white/50 uppercase">Siguiente →</span>
                <span class="font-b line-clamp-2 text-sm group-hover:text-white/90">{nextPost.data.title}</span>
              </a>
            )}
          </div>
        )}
      </nav>
    )
  }
</BaseLayout>
