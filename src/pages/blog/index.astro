---
import BaseLayout from "@/layouts/BaseLayout.astro"

import { getCollection } from "astro:content"

import Breadcrumb from "@/components/Breadcrumb.astro"
import EmptyState from "@/components/EmptyState.astro"

const posts = (await getCollection("blog")).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
---

<BaseLayout title="Blog - Gerencia Blog">
  <Breadcrumb items={[{ label: "Inicio", href: "/" }, { label: "Blog" }]} className="animate-fade-in-down" />

  <h1
    class="font-h metallic-text animate-fade-in-down animate-delay-100 self-start text-start text-5xl leading-tight font-bold tracking-wide text-white sm:self-center"
  >
    Artículos
  </h1>

  <p
    class="font-b animate-fade-in-down animate-delay-200 text-start text-xl leading-relaxed text-white/70 sm:px-0 sm:text-center"
  >
    Explora nuestra biblioteca de artículos dedicados a la gestión estratégica de tecnologías de la información,
    gobernanza digital y dirección de proyectos tecnológicos.
  </p>

  <p class="font-b animate-fade-in-down animate-delay-300 text-sm text-white/50">
    {posts.length} artículo{posts.length !== 1 && "s"} publicado{posts.length !== 1 && "s"}
  </p>

  {
    posts.length === 0 ? (
      <EmptyState />
    ) : (
      <div class="animate-fade-in-down animate-delay-300 mt-16 grid w-full auto-rows-fr grid-cols-1 gap-8">
        {posts.map((p) => (
          <a
            href={`/blog/${p.id}`}
            class="font-b glass-card group timeline-view animate-fade-in animate-range-entry flex h-auto w-full flex-col gap-6 overflow-hidden rounded-3xl p-6 sm:flex-row sm:items-stretch"
          >
            <img
              src={p.data.banner ?? "/banners/default.webp"}
              alt={`Banner de ${p.data.title}`}
              class="h-[200px] w-full shrink-0 rounded-2xl border-2 border-white/20 object-cover sm:h-full sm:w-1/3"
            />

            <div class="flex w-full flex-col">
              <div>
                <div class="mb-2 flex items-center gap-2 text-sm text-white/70">
                  <time datetime={p.data.pubDate.toISOString()}>
                    {p.data.pubDate.toLocaleDateString("es", {
                      year: "numeric",
                      month: "short",
                      day: "numeric",
                    })}
                  </time>
                  <span>•</span>
                  <span>{p.data.author}</span>
                </div>

                <h2 class="mb-3 line-clamp-2 text-2xl font-semibold text-white">{p.data.title}</h2>

                <p class="mb-4 line-clamp-4 leading-relaxed text-white/80 sm:line-clamp-3">{p.data.description}</p>
              </div>

              {p.data.tags && (
                <div class="flex flex-wrap gap-2 pt-2">
                  {p.data.tags.map((tag) => (
                    <span class="rounded-lg bg-white/10 px-3 py-1 text-xs font-medium text-white">#{tag}</span>
                  ))}
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
    )
  }
</BaseLayout>
