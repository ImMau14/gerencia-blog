---
import BaseLayout from "@/layouts/BaseLayout.astro"

import { getCollection } from "astro:content"

import Breadcrumb from "@/components/Breadcrumb.astro"
import PostCard from "@/components/PostCard.astro"
import EmptyState from "@/components/EmptyState.astro"

const posts = await getCollection("blog")
const latestPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 4)
---

<BaseLayout title="Inicio - Gerencia Blog">
  <Breadcrumb items={[{ label: "Inicio" }]} className="animate-fade-in-down" />

  <h1
    class="font-h animate-fade-in-down animate-delay-100 metallic-text text-start text-4xl leading-tight font-bold tracking-wide text-white sm:text-center sm:text-5xl"
  >
    Gerencia Informática Integral: Desarrollo, Mantenimiento y Gestión de Sistemas
  </h1>

  <p
    class="font-b animate-fade-in-down animate-delay-200 text-start text-xl leading-relaxed text-white/70 sm:text-center"
  >
    Artículos informativos sobre gerencia informática, desarrollo de sistemas y gestión de bases de datos.
  </p>

  <div
    class="sm:animate-fade-in-down sm:animate-delay-300 flex w-full flex-col-reverse items-center justify-center gap-4 sm:flex-row"
  >
    <a href="/about" class="w-full sm:w-auto">
      <button
        class="glass-button font-b animate-fade-in-down animate-delay-500 flex w-full cursor-pointer items-center justify-center rounded-full px-10 py-3 font-semibold text-white backdrop-blur-lg sm:w-auto sm:animate-none"
      >
        Más información
      </button>
    </a>

    <a href="/blog" class="w-full sm:w-auto">
      <button
        class="glass-button font-b animate-fade-in-down animate-delay-400 flex w-full cursor-pointer items-center justify-center rounded-full px-10 py-3 font-semibold text-white backdrop-blur-lg sm:w-auto sm:animate-none"
      >
        Ver artículos
      </button>
    </a>
  </div>

  {
    latestPosts.length > 0 ? (
      <section class="mt-20 flex w-full flex-col gap-4">
        <div class="animate-fade-in-down animate-delay-600 sm:animate-delay-400 flex items-baseline justify-between">
          <h2 class="font-b text-base font-semibold text-white/70">Últimos Artículos</h2>
          <a href="/blog" class="font-b text-sm text-white/50 transition-colors hover:text-white">
            Ver todos →
          </a>
        </div>

        <div class="animate-fade-in-down animate-delay-700 sm:animate-delay-500 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-2">
          {latestPosts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      </section>
    ) : (
      <EmptyState />
    )
  }
</BaseLayout>
